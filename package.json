{
  "name": "superteam-projects",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@superteam/arket",
    "start": "npm run start --workspace=@superteam/arket",
    "build": "npm run build --workspace=@superteam/arket",
    "lint": "npm run lint --workspace=@superteam/arket",
    "typecheck": "npm run typecheck --workspace=@superteam/arket",
    "test": "npm run test --workspace=@superteam/arket"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "overrides": {
    "postcss": "$postcss"
  },
  "devDependencies": {
    "postcss": "^8.5.20"
  }
}
